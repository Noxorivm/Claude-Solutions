# Configuración del stack de producción (docker/docker-compose.yml).
# Copia este archivo a docker/.env y rellena los valores reales.
# docker/.env está en .gitignore: NUNCA lo commitees.

# --- Postgres (servicio interno; sin puerto publicado al host) ---
POSTGRES_USER=claude_solutions
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=claude_solutions

# La app se conecta por la red interna del compose: el host es `postgres`.
# Mantén usuario/contraseña/db en sintonía con los POSTGRES_* de arriba.
DATABASE_URL=postgres://claude_solutions:cambia-esta-contrasena@postgres:5432/claude_solutions

# --- better-auth ---
# Genera el secreto con: openssl rand -hex 32
BETTER_AUTH_SECRET=cambia-esto-genera-64-hex
# URL pública de la app (con DOMAIN real: https://tudominio.com).
BETTER_AUTH_URL=http://localhost
NEXT_PUBLIC_APP_URL=http://localhost

# --- Caddy ---
# Dominio público SIN protocolo (p. ej. claude-solutions.example.com).
# Déjalo vacío para la verificación local: Caddy servirá http://localhost.
DOMAIN=

# --- Seed (solo se usa al ejecutar seed.mjs manualmente) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=cambia-esta-contrasena-larga

# --- Subidas (volumen uploads_data del compose) ---
UPLOADS_DIR=/data/uploads

# --- Backups (docker/backup.sh · docker/restore.sh) ---
# Directorio del HOST donde se guardan los backups (rotación: 14 días).
BACKUP_DIR=/var/backups/claude-solutions
